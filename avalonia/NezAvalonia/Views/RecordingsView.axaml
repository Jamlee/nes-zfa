<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NezAvalonia.ViewModels"
             x:Class="NezAvalonia.Views.RecordingsView"
             x:DataType="vm:RecordingsViewModel"
             Background="#0A0A0F">

    <DockPanel Margin="24,20">
        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,20">
            <TextBlock Text="Recordings" FontSize="24" FontWeight="Bold"
                       Foreground="#F0F0F5" VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right" Classes="ghost" Command="{Binding LoadRecordingsCommand}"
                    HorizontalAlignment="Right" Padding="10,8" CornerRadius="8">
                <TextBlock Text="&#x21BB; Refresh" FontSize="12" Foreground="#8888AA"/>
            </Button>
        </DockPanel>

        <!-- Empty state -->
        <StackPanel IsVisible="{Binding !Recordings.Count}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
            <TextBlock Text="No recordings yet" FontSize="16" Foreground="#555577"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Record gameplay using the toolbar button" FontSize="12"
                       Foreground="#555577" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Recordings list -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Recordings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:RecordingEntry">
                        <Border Background="#12121A" CornerRadius="12"
                                BorderBrush="#2A2A44" BorderThickness="1"
                                Padding="14" Margin="0,0,0,8">
                            <DockPanel>
                                <!-- Actions -->
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                            Spacing="6" VerticalAlignment="Center">
                                    <Button Classes="ghost" Padding="8,6" CornerRadius="6"
                                            Command="{Binding $parent[ItemsControl].((vm:RecordingsViewModel)DataContext).CopyPathCommand}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="Copy Path" FontSize="11" Foreground="#8888AA"/>
                                    </Button>
                                    <Button Classes="ghost" Padding="8,6" CornerRadius="6"
                                            Command="{Binding $parent[ItemsControl].((vm:RecordingsViewModel)DataContext).OpenFolderCommand}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="Open Folder" FontSize="11" Foreground="#8888AA"/>
                                    </Button>
                                    <Button Classes="ghost" Padding="8,6" CornerRadius="6"
                                            Command="{Binding $parent[ItemsControl].((vm:RecordingsViewModel)DataContext).DeleteCommand}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="Delete" FontSize="11" Foreground="#FF6B6B"/>
                                    </Button>
                                </StackPanel>

                                <!-- Info -->
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding FileName}" FontSize="14"
                                               FontWeight="SemiBold" Foreground="#F0F0F5"/>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="{Binding DateText}" FontSize="11" Foreground="#555577"/>
                                        <TextBlock Text="{Binding SizeText}" FontSize="11" Foreground="#555577"/>
                                    </StackPanel>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</UserControl>
