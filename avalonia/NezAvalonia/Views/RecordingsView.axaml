<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NezAvalonia.ViewModels"
             x:Class="NezAvalonia.Views.RecordingsView"
             x:DataType="vm:RecordingsViewModel"
             Background="#0A0A0F">

  <Panel>
    <DockPanel Margin="24,20">
        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,20">
            <TextBlock Text="Recordings" FontSize="24" FontWeight="Bold"
                       Foreground="#F0F0F5" VerticalAlignment="Center"/>
            <Button DockPanel.Dock="Right" Classes="ghost" Command="{Binding LoadRecordingsCommand}"
                    HorizontalAlignment="Right" Padding="10,8" CornerRadius="8">
                <TextBlock Text="&#x21BB; Refresh" FontSize="12" Foreground="#8888AA"/>
            </Button>
        </DockPanel>

        <!-- Empty state -->
        <StackPanel IsVisible="{Binding !Recordings.Count}"
                    HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
            <TextBlock Text="No recordings yet" FontSize="16" Foreground="#555577"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Record gameplay using the toolbar button" FontSize="12"
                       Foreground="#555577" HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- Recordings list -->
        <ScrollViewer>
            <ItemsControl ItemsSource="{Binding Recordings}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:RecordingEntry">
                        <Border Background="#12121A" CornerRadius="12"
                                BorderBrush="#2A2A44" BorderThickness="1"
                                Padding="14" Margin="0,0,0,8"
                                PointerPressed="OnRecordingClick">
                            <DockPanel>
                                <!-- GIF Thumbnail -->
                                <Border DockPanel.Dock="Left" Width="60" Height="56"
                                        CornerRadius="8" Background="#1A1A2E"
                                        ClipToBounds="True" Margin="0,0,12,0">
                                    <Panel>
                                        <Image Source="{Binding Thumbnail}"
                                               Stretch="UniformToFill"/>
                                        <TextBlock Text="GIF" FontSize="10" FontWeight="SemiBold"
                                                   Foreground="#6C63FF" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   IsVisible="{Binding Thumbnail, Converter={x:Static ObjectConverters.IsNull}}"/>
                                    </Panel>
                                </Border>

                                <!-- Actions -->
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                            Spacing="6" VerticalAlignment="Center">
                                    <Button Classes="ghost" Padding="8,6" CornerRadius="6"
                                            Command="{Binding $parent[ItemsControl].((vm:RecordingsViewModel)DataContext).CopyPathCommand}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="Copy Path" FontSize="11" Foreground="#8888AA"/>
                                    </Button>
                                    <Button Classes="ghost" Padding="8,6" CornerRadius="6"
                                            Command="{Binding $parent[ItemsControl].((vm:RecordingsViewModel)DataContext).OpenFolderCommand}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="Open Folder" FontSize="11" Foreground="#8888AA"/>
                                    </Button>
                                    <Button Classes="ghost" Padding="8,6" CornerRadius="6"
                                            Command="{Binding $parent[ItemsControl].((vm:RecordingsViewModel)DataContext).DeleteCommand}"
                                            CommandParameter="{Binding}">
                                        <TextBlock Text="Delete" FontSize="11" Foreground="#FF6B6B"/>
                                    </Button>
                                </StackPanel>

                                <!-- Info -->
                                <StackPanel Spacing="2" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding GameName}" FontSize="14"
                                               FontWeight="SemiBold" Foreground="#F0F0F5"/>
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <TextBlock Text="{Binding DateText}" FontSize="11" Foreground="#555577"/>
                                        <TextBlock Text="{Binding SizeText}" FontSize="11" Foreground="#555577"/>
                                    </StackPanel>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>

    <!-- Preview overlay -->
    <Border IsVisible="{Binding IsPreviewOpen}"
            Background="#CC000000" ZIndex="100"
            PointerPressed="OnPreviewOverlayClick">
        <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="#12121A" CornerRadius="16"
                BorderBrush="#2A2A44" BorderThickness="1"
                MaxWidth="540" MaxHeight="540"
                Padding="0">
            <StackPanel>
                <!-- GIF preview image -->
                <Border CornerRadius="16,16,0,0" ClipToBounds="True"
                        MaxHeight="420" MaxWidth="512"
                        HorizontalAlignment="Center">
                    <Image Source="{Binding SelectedRecording.Thumbnail}"
                           Stretch="Uniform" MaxWidth="512" MaxHeight="420"/>
                </Border>
                <!-- Info bar -->
                <Border Padding="14,10" CornerRadius="0,0,16,16">
                    <DockPanel>
                        <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <Button Classes="ghost" Padding="6,4" CornerRadius="6"
                                    Command="{Binding CopyPathCommand}"
                                    CommandParameter="{Binding SelectedRecording}">
                                <TextBlock Text="Copy Path" FontSize="11" Foreground="#8888AA"/>
                            </Button>
                            <Button Classes="ghost" Padding="6,4" CornerRadius="6"
                                    Command="{Binding OpenFolderCommand}"
                                    CommandParameter="{Binding SelectedRecording}">
                                <TextBlock Text="Open Folder" FontSize="11" Foreground="#8888AA"/>
                            </Button>
                        </StackPanel>
                        <TextBlock DockPanel.Dock="Right" FontSize="11" Foreground="#555577"
                                   VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Run Text="{Binding SelectedRecording.GameName}"/>
                            <Run Text="  •  "/>
                            <Run Text="{Binding SelectedRecording.SizeText}"/>
                        </TextBlock>
                    </DockPanel>
                </Border>
            </StackPanel>
        </Border>
    </Border>
  </Panel>
</UserControl>
