<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:NezAvalonia.ViewModels"
             x:Class="NezAvalonia.Views.LibraryView"
             x:DataType="vm:LibraryViewModel">

    <DockPanel Margin="0">
        <!-- Header - matches Flutter ShaderMask gradient title -->
        <DockPanel DockPanel.Dock="Top" Margin="24,20,24,8">
            <DockPanel DockPanel.Dock="Left">
                <TextBlock Text="Nez" FontSize="26" FontWeight="800"
                           Foreground="#FFFFFF">
                    <TextBlock.OpacityMask>
                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                            <GradientStop Color="#6C5CE7" Offset="0"/>
                            <GradientStop Color="#A29BFE" Offset="1"/>
                        </LinearGradientBrush>
                    </TextBlock.OpacityMask>
                </TextBlock>
            </DockPanel>
            <Button DockPanel.Dock="Right" Name="AddRomBtn"
                    VerticalAlignment="Center" CornerRadius="10"
                    Padding="16,10"
                    Background="#1E1E36"
                    BorderBrush="#2D2D50"
                    BorderThickness="1"
                    Cursor="Hand">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="M19 13h-6v-6h-2v6H5v2h6v6h2v-6h6z"
                              Foreground="#A29BFE" Width="16" Height="16"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="Add ROM" FontSize="13" FontWeight="SemiBold"
                               Foreground="#C0C0D0" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </DockPanel>

        <!-- Search -->
        <Border DockPanel.Dock="Top" Margin="24,16,24,0"
                Background="#12121A" CornerRadius="14"
                BorderBrush="#1E1E36" BorderThickness="1"
                Padding="12,0"
                Name="SearchBorder">
            <Grid ColumnDefinitions="Auto,*">
                <PathIcon Grid.Column="0" Data="M15.5 14.79l-.32 0a5.4 5.4 0 01-7.58 7.58 5.4 5.4 0 01-.32-7.58 5.4 5.4 0 01.42-.32L15.5 14.79zM21 11h-2V6h2v5zm-4-3c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm4.5 2c-.83 0-1.5-.67-1.5-1.5S18.67 9 19.5 9s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"
                          Foreground="#555577" Width="18" Height="18"
                          VerticalAlignment="Center" Margin="10,0,0,0"/>
                <TextBox Grid.Column="1" Text="{Binding SearchQuery}"
                         Classes="search-input"
                         PlaceholderText="Search ROMs..."
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="#F0F0F5"
                         FontSize="14"
                         Padding="8,10"
                         CornerRadius="0"
                         Name="SearchBox"/>
            </Grid>
        </Border>

        <!-- Content -->
        <Panel Margin="28,20,28,0">
            <!-- Empty state -->
            <StackPanel Name="EmptyState"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="20">
                <Border Width="80" Height="80" CornerRadius="20"
                        Background="#12121A"
                        HorizontalAlignment="Center">
                    <PathIcon Data="M10 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2h-8l-2-2z"
                              Foreground="#555577" Width="36" Height="36"/>
                </Border>
                <StackPanel Spacing="6" HorizontalAlignment="Center">
                    <TextBlock Text="No ROMs loaded" FontSize="18" FontWeight="SemiBold"
                               Foreground="#8888AA" HorizontalAlignment="Center"/>
                    <TextBlock Text="Add a .nes ROM file to get started" FontSize="13"
                               Foreground="#555577" HorizontalAlignment="Center"/>
                </StackPanel>
                <Button Name="AddRomEmptyBtn"
                        HorizontalAlignment="Center" Margin="0,4,0,0"
                        CornerRadius="10" Padding="18,10"
                        Background="#1E1E36"
                        BorderBrush="#2D2D50"
                        BorderThickness="1"
                        Cursor="Hand">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <PathIcon Data="M19 13h-6v-6h-2v6H5v2h6v6h2v-6h6z"
                                  Foreground="#A29BFE" Width="16" Height="16"
                                  VerticalAlignment="Center"/>
                        <TextBlock Text="Add ROM" FontSize="14" FontWeight="SemiBold"
                                   Foreground="#C0C0D0"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- ROM grid -->
            <ScrollViewer Name="RomGrid">
                <ItemsControl ItemsSource="{Binding FilteredRoms}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:RomEntry">
                            <Button Width="200" Margin="0,0,14,14"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Padding="0" CornerRadius="14"
                                    Cursor="Hand"
                                    Tag="{Binding}">
                                <Border Classes="game-card" ClipToBounds="True">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Top" Height="110"
                                                Background="#12121A">
                                            <Panel>
                                                <!-- Subtle gradient overlay -->
                                                <Border CornerRadius="14,14,0,0"
                                                        Opacity="0.08">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                                                            <GradientStop Color="#6C5CE7" Offset="0"/>
                                                            <GradientStop Color="#A29BFE" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                                <PathIcon Data="M21 6H3c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h18c1.1 0 2-.9 2-2V8c0-1.1-.9-2-2-2zm-10 7H8v3H6v-3H3v-2h3V8h2v3h3v2zm4.5 2c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5zm4-3c-.83 0-1.5-.67-1.5-1.5S18.67 9 19.5 9s1.5.67 1.5 1.5-.67 1.5-1.5 1.5z"
                                                          Foreground="#A29BFE"
                                                          Opacity="0.25"
                                                          Width="44" Height="44"
                                                          HorizontalAlignment="Center"
                                                          VerticalAlignment="Center"/>
                                                <!-- Delete button -->
                                                <Button HorizontalAlignment="Right" VerticalAlignment="Top"
                                                        Margin="4,4" Padding="4"
                                                        Width="24" Height="24"
                                                        Background="#44000000" CornerRadius="12"
                                                        BorderThickness="0" Cursor="Hand"
                                                        Command="{Binding $parent[ItemsControl].((vm:LibraryViewModel)DataContext).RemoveRomCommand}"
                                                        CommandParameter="{Binding}">
                                                    <PathIcon Data="M19 6.41L17.59 5 12 10.59 6.41 5 5 6.41 10.59 12 5 17.59 6.41 19 12 13.41 17.59 19 19 17.59 13.41 12z"
                                                              Foreground="#FF6B6B" Width="12" Height="12"/>
                                                </Button>
                                            </Panel>
                                        </Border>
                                        <StackPanel Margin="14,12" Spacing="5">
                                            <TextBlock Text="{Binding Name}"
                                                       FontSize="14" FontWeight="SemiBold"
                                                       Foreground="#F0F0F5"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding SizeText}"
                                                       FontSize="12"
                                                       Foreground="#8888AA"/>
                                            <TextBlock Text="{Binding Path}"
                                                       FontSize="10"
                                                       Foreground="#555577"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </Button>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Panel>
    </DockPanel>
</UserControl>
